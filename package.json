{
  "name": "flipfolio",
  "version": "0.1.0",
  "private": false,
  "description": "A framework-agnostic 3D folder gallery for the web. Real content in manila folders, with stack, grid, and carousel modes.",
  "type": "module",
  "license": "MIT",
  "author": "Kirthi Balakrishnan",
  "homepage": "https://kirthi.studio",
  "keywords": [
    "gallery",
    "folder",
    "3d",
    "carousel",
    "ui",
    "component",
    "css-3d",
    "web-component",
    "accessibility"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./element": {
      "types": "./dist/element.d.ts",
      "import": "./dist/element.js",
      "require": "./dist/element.cjs"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js",
      "require": "./dist/react.cjs"
    },
    "./vue": {
      "types": "./dist/vue.d.ts",
      "import": "./dist/vue.js",
      "require": "./dist/vue.cjs"
    },
    "./styles.css": "./dist/folder-gallery.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "check": "node --check src/folder-gallery.js && node --check src/folder-gallery-element.js && node --check src/folder-gallery-vue.js",
    "build": "tsup",
    "test": "vitest run",
    "prepublishOnly": "npm run build",
    "serve": "python3 -m http.server 5177"
  },
  "peerDependencies": {
    "react": ">=18",
    "vue": ">=3.3"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  },
  "devDependencies": {
    "jsdom": "^25.0.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.3.5",
    "typescript": "^6.0.3",
    "vitest": "^2.1.8",
    "vue": "^3.5.39"
  }
}
