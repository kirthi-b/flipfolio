{
  "name": "folder-gallery",
  "version": "0.1.0",
  "private": true,
  "description": "A framework-agnostic 3D folder gallery for the web — browse real content in manila folders, with stack, grid, and carousel modes.",
  "type": "module",
  "license": "MIT",
  "author": "Kirthi Balakrishnan",
  "homepage": "https://kirthi.studio",
  "keywords": [
    "gallery",
    "folder",
    "3d",
    "carousel",
    "ui",
    "component",
    "css-3d",
    "web-component",
    "accessibility"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./element": {
      "types": "./dist/element.d.ts",
      "import": "./dist/element.js",
      "require": "./dist/element.cjs"
    },
    "./styles.css": "./dist/folder-gallery.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "check": "node --check src/folder-gallery.js",
    "build": "tsup",
    "prepublishOnly": "npm run build",
    "serve": "python3 -m http.server 5177"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^6.0.3"
  }
}
